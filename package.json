{
  "name": "llmthink",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "schemas"
  ],
  "bin": {
    "llmthink": "./dist/cli.js",
    "llmthink-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit": "tsx src/cli.ts",
    "verify-examples": "tsx src/verify-examples.ts",
    "mcp": "tsx src/mcp/server.ts",
    "typecheck:extension": "npm --prefix vscode-extension run typecheck",
    "build:extension": "npm --prefix vscode-extension run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}