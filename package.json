{
  "name": "llmthink",
  "version": "0.2.0",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/mako10k/llmthink.git"
  },
  "homepage": "https://github.com/mako10k/llmthink",
  "bugs": {
    "url": "https://github.com/mako10k/llmthink/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "schemas"
  ],
  "bin": {
    "llmthink": "./dist/cli.js",
    "llmthink-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cli": "tsx src/cli.ts",
    "verify-examples": "tsx src/verify-examples.ts",
    "mcp": "tsx src/mcp/server.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deadcode": "knip",
    "code-clone": "jscpd --config .jscpd.json",
    "complexity": "eslint src vscode-extension/src --ext .ts --rule 'complexity: [error, 12]' --rule 'sonarjs/cognitive-complexity: [error, 20]'",
    "typecheck:extension": "npm --prefix vscode-extension run typecheck",
    "build:extension": "npm --prefix vscode-extension run build",
    "package:vsix": "npm --prefix vscode-extension run package:vsix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.15.21",
    "eslint": "^9.30.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "globals": "^16.3.0",
    "jscpd": "^4.0.5",
    "knip": "^5.61.3",
    "prettier": "^3.6.2",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.35.1",
    "typescript": "^5.8.3"
  }
}
