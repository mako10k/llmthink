{
  "name": "llmthink-vscode-extension",
  "displayName": "LLMThink",
  "description": "Thought-audit tools for the LLMThink DSL.",
  "version": "0.4.2",
  "publisher": "mako10k",
  "private": true,
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mako10k/llmthink.git"
  },
  "homepage": "https://github.com/mako10k/llmthink",
  "bugs": {
    "url": "https://github.com/mako10k/llmthink/issues"
  },
  "files": [
    "dist",
    "media",
    "syntaxes",
    "snippets",
    "language-configuration.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "llmthink",
        "aliases": [
          "LLMThink DSL",
          "llmthink"
        ],
        "extensions": [
          ".dsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "llmthink",
        "scopeName": "source.llmthink",
        "path": "./syntaxes/llmthink.tmLanguage.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "llmthink.preview",
        "displayName": "LLMThink Preview",
        "selector": [
          {
            "filenamePattern": "*.dsl"
          }
        ],
        "priority": "option"
      }
    ],
    "snippets": [
      {
        "language": "llmthink",
        "path": "./snippets/dslql.code-snippets"
      }
    ],
    "languageModelTools": [
      {
        "name": "llmthink-dsl",
        "toolReferenceName": "llmthink-dsl",
        "displayName": "LLMThink DSL",
        "modelDescription": "LLMThink DSL operations. Use action=audit to audit and auto-register DSL text, or action=help for syntax guidance.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "audit",
                "help"
              ],
              "description": "DSL operation to run."
            },
            "dslText": {
              "type": "string",
              "description": "Full DSL text to audit. If omitted, the tool audits the active editor document."
            },
            "documentId": {
              "type": "string",
              "description": "Optional logical document identifier to use in the audit report."
            },
            "thoughtId": {
              "type": "string",
              "description": "Optional thought identifier to reuse for re-audit or later lifecycle actions."
            },
            "topic": {
              "type": "string",
              "description": "Optional help topic such as syntax, query, usecases, samples, or channels."
            },
            "subtopic": {
              "type": "string",
              "description": "Optional help subtopic such as functions, examples, or a sample id."
            },
            "detail": {
              "type": "string",
              "enum": [
                "index",
                "quick",
                "detail"
              ],
              "description": "Optional help detail level."
            }
          }
        }
      },
      {
        "name": "llmthink-thought",
        "toolReferenceName": "llmthink-thought",
        "displayName": "LLMThink Thought",
        "modelDescription": "LLMThink thought operations. Use action=show with view=semantic-audit or semantic-audit-pairs to inspect semantic audit state, or action=semantic-audit to save one.",
        "canBeReferencedInPrompt": true,
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "show",
                "semantic-audit"
              ],
              "description": "Thought operation to run."
            },
            "thoughtId": {
              "type": "string",
              "description": "Optional thought identifier. If omitted, the active editor document is used when possible."
            },
            "view": {
              "type": "string",
              "enum": [
                "summary",
                "draft",
                "final",
                "audit",
                "reflections",
                "semantic-audit",
                "semantic-audit-pairs"
              ],
              "description": "Thought view to render."
            },
            "decisionId": {
              "type": "string",
              "description": "Decision id for action=semantic-audit."
            },
            "supportId": {
              "type": "string",
              "description": "Support statement id for action=semantic-audit."
            },
            "verdict": {
              "type": "string",
              "enum": [
                "supported",
                "unsupported",
                "mixed",
                "unknown"
              ],
              "description": "Semantic audit verdict for action=semantic-audit."
            },
            "reason": {
              "type": "string",
              "description": "Reason text for action=semantic-audit."
            },
            "auditId": {
              "type": "string",
              "description": "Optional semantic audit id."
            },
            "reviewer": {
              "type": "string",
              "description": "Optional reviewer metadata."
            },
            "model": {
              "type": "string",
              "description": "Optional model metadata."
            },
            "auditedAt": {
              "type": "string",
              "description": "Optional audited_at metadata."
            },
            "sourceThoughtId": {
              "type": "string",
              "description": "Optional source thought metadata."
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "llmthink.dslAudit",
        "title": "LLMThink: DSL Audit"
      },
      {
        "command": "llmthink.dslReportShow",
        "title": "LLMThink: DSL Report Show"
      },
      {
        "command": "llmthink.dslPreview",
        "title": "LLMThink: DSL Preview Here",
        "icon": {
          "light": "./media/preview-light.svg",
          "dark": "./media/preview-dark.svg"
        }
      },
      {
        "command": "llmthink.dslPreviewBeside",
        "title": "LLMThink: DSL Preview to Side",
        "icon": {
          "light": "./media/preview-side-light.svg",
          "dark": "./media/preview-side-dark.svg"
        }
      },
      {
        "command": "llmthink.thoughtDraft",
        "title": "LLMThink: Thought Draft"
      },
      {
        "command": "llmthink.thoughtRelate",
        "title": "LLMThink: Thought Relate"
      },
      {
        "command": "llmthink.thoughtAudit",
        "title": "LLMThink: Thought Audit"
      },
      {
        "command": "llmthink.thoughtReflect",
        "title": "LLMThink: Thought Reflect"
      },
      {
        "command": "llmthink.thoughtSemanticAudit",
        "title": "LLMThink: Thought Semantic Audit"
      },
      {
        "command": "llmthink.thoughtFinalize",
        "title": "LLMThink: Thought Finalize"
      },
      {
        "command": "llmthink.thoughtReflections",
        "title": "LLMThink: Thought Reflections"
      },
      {
        "command": "llmthink.thoughtHistory",
        "title": "LLMThink: Thought History"
      },
      {
        "command": "llmthink.thoughtSearch",
        "title": "LLMThink: Thought Search"
      },
      {
        "command": "llmthink.thoughtList",
        "title": "LLMThink: Thought List"
      },
      {
        "command": "llmthink.thoughtDelete",
        "title": "LLMThink: Thought Delete"
      },
      {
        "command": "llmthink.lsp.restart",
        "title": "LLMThink: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "LLMThink",
      "properties": {
        "llmthink.languageServer.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "LSP サーバの実行ファイルまたはスクリプトへの絶対パス、または PATH 上のコマンド名。未指定または解決不可のときは workspace の build/llmthink-lsp.js、PATH 上の llmthink-lsp、最後に拡張機能同梱の fallback を順に試します。"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "llmthink.dslPreview",
          "when": "editorLangId == llmthink && !notebookEditorFocused",
          "group": "navigation@1"
        },
        {
          "command": "llmthink.dslPreviewBeside",
          "when": "editorLangId == llmthink && !notebookEditorFocused",
          "group": "navigation@2"
        }
      ],
      "modalEditor/editorTitle": [
        {
          "command": "llmthink.dslPreview",
          "when": "editorLangId == llmthink && !notebookEditorFocused",
          "group": "navigation@1"
        },
        {
          "command": "llmthink.dslPreviewBeside",
          "when": "editorLangId == llmthink && !notebookEditorFocused",
          "group": "navigation@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "llmthink.dslPreview",
          "when": "resourceLangId == llmthink",
          "group": "1_open"
        },
        {
          "command": "llmthink.dslPreviewBeside",
          "when": "resourceLangId == llmthink",
          "group": "1_open@2"
        }
      ],
      "editor/context": [
        {
          "command": "llmthink.dslPreview",
          "when": "editorLangId == llmthink",
          "group": "navigation"
        },
        {
          "command": "llmthink.dslPreviewBeside",
          "when": "editorLangId == llmthink",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "llmthink.dslPreview",
          "when": "resourceExtname == .dsl",
          "group": "navigation"
        },
        {
          "command": "llmthink.dslPreviewBeside",
          "when": "resourceExtname == .dsl",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm --prefix .. run build && node ./build.mjs",
    "typecheck": "npm --prefix .. run build && tsc -p tsconfig.json --noEmit",
    "package:vsix": "npx -y @vscode/vsce@3.9.1 package --out llmthink.vsix"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/vscode": "^1.99.0",
    "elkjs": "^0.11.1",
    "esbuild": "^0.25.11",
    "typescript": "^5.8.3",
    "vscode-languageclient": "^9.0.1"
  }
}
