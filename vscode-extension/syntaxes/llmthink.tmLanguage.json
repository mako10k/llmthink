{
  "scopeName": "source.llmthink",
  "name": "LLMThink DSL",
  "patterns": [
    { "include": "#comments" },
    { "include": "#blockTextDescription" },
    { "include": "#blockTextBody" },
    { "include": "#keywords" },
    { "include": "#declHeaders" },
    { "include": "#dslqlFunctions" },
    { "include": "#dslqlConstants" },
    { "include": "#operators" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.llmthink",
          "match": "^\\s*#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.llmthink",
          "match": "\\b(framework|domain|description|problem|annotation|step|premise|viewpoint|axis|partition|on|evidence|decision|comparison|relation|based_on|pending|query|requires|forbids|warns)\\b"
        },
        {
          "name": "keyword.operator.relation.llmthink",
          "match": "\\b(preferred_over|weaker_than|incomparable|counterexample_to)\\b"
        }
      ]
    },
    "declHeaders": {
      "patterns": [
        {
          "name": "entity.name.type.framework.llmthink",
          "match": "(?<=\\bframework\\s)[A-Za-z][A-Za-z0-9_-]*"
        },
        {
          "name": "entity.name.type.domain.llmthink",
          "match": "(?<=\\bdomain\\s)[A-Za-z][A-Za-z0-9_-]*(?=:)"
        },
        {
          "name": "entity.name.type.problem.llmthink",
          "match": "(?<=\\bproblem\\s)[A-Za-z][A-Za-z0-9_-]*(?=:)"
        },
        {
          "name": "entity.name.function.step.llmthink",
          "match": "(?<=\\bstep\\s)[A-Za-z][A-Za-z0-9_-]*(?=:)"
        },
        {
          "name": "entity.name.function.statement.llmthink",
          "match": "(?<=\\b(premise|viewpoint|partition|evidence|decision|comparison|pending)\\s)[A-Za-z][A-Za-z0-9_-]*"
        },
        {
          "name": "storage.type.annotation.llmthink",
          "match": "(?<=\\bannotation\\s)(explanation|rationale|status|caveat|todo|orphan_future|orphan_reference)(?=:)"
        },
        {
          "name": "entity.name.function.query.llmthink",
          "match": "(?<=\\bquery\\s)[A-Za-z][A-Za-z0-9_-]*(?=:)"
        },
        {
          "name": "variable.parameter.partition.llmthink",
          "match": "^\\s*[A-Za-z][A-Za-z0-9_-]*(?=\\s*:=)"
        }
      ]
    },
    "blockTextDescription": {
      "begin": "^(\\s*)(description)(\\s+)(\\|)\\s*$",
      "beginCaptures": {
        "2": { "name": "keyword.control.llmthink" },
        "4": { "name": "punctuation.definition.block.llmthink" }
      },
      "while": "^(\\1\\s{2,}.*|\\s*)$",
      "patterns": [
        {
          "name": "string.unquoted.block.llmthink",
          "match": "^\\1\\s{2,}.*$"
        }
      ]
    },
    "blockTextBody": {
      "begin": "^(\\s*)(\\|)\\s*$",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.block.llmthink" }
      },
      "while": "^(\\1\\s{2,}.*|\\s*)$",
      "patterns": [
        {
          "name": "string.unquoted.block.llmthink",
          "match": "^\\1\\s{2,}.*$"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.llmthink",
          "match": ":="
        },
        {
          "name": "keyword.operator.logical.dslql.llmthink",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.comparison.dslql.llmthink",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.pipe.dslql.llmthink",
          "match": "\\|(?=.*\\S)"
        },
        {
          "name": "meta.path-access.dslql.llmthink",
          "match": "\\.[A-Za-z_][A-Za-z0-9_-]*\\??|\\[\\]"
        },
        {
          "name": "punctuation.separator.delimiter.llmthink",
          "match": ":|,"
        }
      ]
    },
    "dslqlFunctions": {
      "patterns": [
        {
          "name": "support.function.dslql.llmthink",
          "match": "\\b(select|map|sort_by|limit|unique_by|related_decisions|audit_findings|based_on_refs|upstream|downstream|len|score|kind|has_open_pending)\\b(?=\\s*(\\(|\\||$))"
        }
      ]
    },
    "dslqlConstants": {
      "patterns": [
        {
          "name": "constant.language.dslql.llmthink",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.llmthink",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.llmthink",
          "match": "\\\\."
        }
      ]
    }
  }
}