{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/audit-result.schema.json",
  "title": "Thought Audit Result",
  "description": "思考監査エンジンの出力契約",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "engine_version",
    "document_id",
    "summary",
    "results"
  ],
  "properties": {
    "engine_version": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fatal_count",
        "error_count",
        "warning_count",
        "info_count",
        "hint_count"
      ],
      "properties": {
        "fatal_count": {
          "type": "integer",
          "minimum": 0
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        },
        "info_count": {
          "type": "integer",
          "minimum": 0
        },
        "hint_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/result"
      }
    },
    "query_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/queryResult"
      },
      "default": []
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "enum": [
        "contradiction",
        "contradiction_candidate",
        "contract_violation",
        "mece_assessment",
        "semantic_hint",
        "query_result"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "fatal",
        "error",
        "warning",
        "info",
        "hint"
      ]
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id"
      ],
      "properties": {
        "ref_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "step_id": {
          "type": "string"
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_id",
        "category",
        "severity",
        "target_refs",
        "message"
      ],
      "properties": {
        "issue_id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "target_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string"
        },
        "suggestion": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "queryResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_id",
        "severity",
        "items"
      ],
      "properties": {
        "query_id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "const": "hint"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "ref_id"
            ],
            "properties": {
              "ref_id": {
                "type": "string",
                "minLength": 1
              },
              "score": {
                "type": "number"
              },
              "explanation": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}